{
  "name": "flowaibuilder",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "npm run dev -w packages/server",
    "dev:ui": "npm run dev -w packages/ui",
    "build": "npm run build -w packages/shared && npm run build -w packages/server && npm run build -w packages/ui",
    "build:server": "npm run build -w packages/server",
    "build:ui": "npm run build -w packages/ui",
    "test": "npm run test -w packages/server",
    "db:push": "npm run db:push -w packages/server",
    "db:migrate": "npm run db:migrate -w packages/server",
    "db:studio": "npm run db:studio -w packages/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
